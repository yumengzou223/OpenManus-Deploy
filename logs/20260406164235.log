2026-04-06 16:44:03.384 | INFO     | app.agent.toolcall:think:89 - 🔧 Tool arguments: {"code": "import requests\nfrom bs4 import BeautifulSoup\nimport json\nfrom datetime import datetime, timedelta\nimport time\n\n# 定义要搜索的新闻网站\nnews_sites = [\n    {\n        'name': '新浪新闻',\n        'url': 'https://news.sina.com.cn',\n        'search_url': 'https://search.sina.com.cn/?q={}&c=news'\n    },\n    {\n        'name': '腾讯新闻',\n        'url': 'https://news.qq.com',\n        'search_url': 'https://new.qq.com/search?q={}'\n    },\n    {\n        'name': '网易新闻',\n        'url': 'https://news.163.com',\n        'search_url': 'https://so.163.com/search/news?keyword={}'\n    }\n]\n\n# 搜索关键词\nkeywords = ['大模型', '大语言模型', 'LLM', '人工智能模型']\n\n# 存储收集到的新闻\ncollected_news = []\n\nprint(\"开始搜索大模型相关新闻...\")\nprint(\"=\" * 50)\n\n# 尝试从每个新闻网站搜索\nfor site in news_sites:\n    print(f\"\\n正在搜索 {site['name']}...\")\n    \n    for keyword in keywords:\n        try:\n            # 构建搜索URL\n            search_url = site['search_url'].format(keyword)\n            print(f\"搜索关键词: {keyword}\")\n            print(f\"搜索URL: {search_url}\")\n            \n            # 发送请求\n            headers = {\n                'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36'\n            }\n            \n            response = requests.get(search_url, headers=headers, timeout=10)\n            \n            if response.status_code == 200:\n                soup = BeautifulSoup(response.text, 'html.parser')\n                \n                # 尝试提取新闻标题和链接\n                # 不同网站的HTML结构不同，这里使用通用方法\n                news_items = []\n                \n                # 查找可能的新闻链接\n                for link in soup.find_all('a', href=True):\n                    href = link['href']\n                    text = link.get_text(strip=True)\n                    \n                    # 过滤条件：链接包含新闻相关关键词，且文本长度适中\n                    if (any(kw in text.lower() for kw in ['模型', 'ai', '人工智能', 'llm', 'gpt']) or \n                        any(kw in href for kw in ['news', 'article', 'report'])) and len(text) > 10:\n                        \n                        # 确保是有效的新闻链接\n                        if href.startswith('http') and 'javascript' not in href:\n                            news_items.append({\n                                'title': text,\n                                'url': href,\n                                'source': site['name'],\n                                'keyword': keyword\n                            })\n                \n                # 去重\n                unique_news = []\n                seen_titles = set()\n                for item in news_items:\n                    if item['title'] not in seen_titles:\n                        seen_titles.add(item['title'])\n                        unique_news.append(item)\n                \n                print(f\"找到 {len(unique_news)} 条相关新闻\")\n                \n                # 添加到总列表\n                for item in unique_news[:5]:  # 每个关键词最多取5条\n                    collected_news.append(item)\n                \n            else:\n                print(f\"请求失败，状态码: {response.status_code}\")\n                \n        except Exception as e:\n            print(f\"搜索 {keyword} 时出错: {str(e)}\")\n        \n        time.sleep(1)  # 避免请求过于频繁\n\nprint(\"\\n\" + \"=\" * 50)\nprint(f\"总共收集到 {len(collected_news)} 条新闻\")\n\n# 显示收集到的新闻\nif collected_news:\n    print(\"\\n收集到的新闻列表:\")\n    print(\"-\" * 50)\n    for i, news in enumerate(collected_news[:10], 1):  # 只显示前10条\n        print(f\"{i}. {news['title']}\")\n        print(f\"   来源: {news['source']} | 关键词: {news['keyword']}\")\n        print(f\"   链接: {news['url'][:80]}...\")\n        print()\nelse:\n    print(\"未找到相关新闻\")"}
