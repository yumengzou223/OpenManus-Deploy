2026-04-07 20:54:49.821 | INFO     | app.agent.toolcall:think:89 - 🔧 Tool arguments: {"code": "import requests\nfrom bs4 import BeautifulSoup\nimport json\nimport re\nfrom datetime import datetime\n\n# 尝试从arXiv获取粒子群算法相关论文\ndef search_arxiv_papers(keyword, max_results=20):\n    \"\"\"从arXiv搜索相关论文\"\"\"\n    base_url = \"https://arxiv.org/search/\"\n    params = {\n        'query': keyword,\n        'searchtype': 'all',\n        'abstracts': 'show',\n        'order': '-announced_date_first',\n        'size': max_results\n    }\n    \n    try:\n        response = requests.get(base_url, params=params, timeout=30)\n        response.raise_for_status()\n        soup = BeautifulSoup(response.content, 'html.parser')\n        \n        papers = []\n        results = soup.find_all('li', class_='arxiv-result')\n        \n        for result in results[:max_results]:\n            try:\n                # 提取标题\n                title_elem = result.find('p', class_='title')\n                title = title_elem.text.strip() if title_elem else \"No title\"\n                \n                # 提取作者\n                authors_elem = result.find('p', class_='authors')\n                authors = authors_elem.text.strip() if authors_elem else \"No authors\"\n                \n                # 提取摘要\n                abstract_elem = result.find('p', class_='abstract')\n                abstract = abstract_elem.text.strip() if abstract_elem else \"No abstract\"\n                \n                # 提取日期\n                date_elem = result.find('p', class_='is-size-7')\n                date_text = date_elem.text.strip() if date_elem else \"\"\n                date_match = re.search(r'(\\d{4}-\\d{2}-\\d{2})', date_text)\n                date = date_match.group(1) if date_match else \"\"\n                \n                # 提取链接\n                link_elem = result.find('a', title='Abstract')\n                link = \"https://arxiv.org\" + link_elem['href'] if link_elem else \"\"\n                \n                papers.append({\n                    'title': title,\n                    'authors': authors,\n                    'abstract': abstract,\n                    'date': date,\n                    'link': link\n                })\n            except Exception as e:\n                print(f\"Error parsing paper: {e}\")\n                continue\n        \n        return papers\n    except Exception as e:\n        print(f\"Error fetching from arXiv: {e}\")\n        return []\n\n# 搜索粒子群算法改进相关的关键词\nkeywords = [\n    \"particle swarm optimization improvement\",\n    \"PSO algorithm enhancement\",\n    \"particle swarm optimization variants\",\n    \"PSO hybrid algorithms\",\n    \"adaptive particle swarm optimization\"\n]\n\nall_papers = []\nfor keyword in keywords:\n    print(f\"\\n搜索关键词: {keyword}\")\n    papers = search_arxiv_papers(keyword, max_results=10)\n    all_papers.extend(papers)\n    print(f\"找到 {len(papers)} 篇论文\")\n\n# 去重\nunique_papers = []\nseen_titles = set()\nfor paper in all_papers:\n    if paper['title'] not in seen_titles:\n        seen_titles.add(paper['title'])\n        unique_papers.append(paper)\n\nprint(f\"\\n总共找到 {len(unique_papers)} 篇不重复的论文\")\n\n# 按日期排序\nunique_papers.sort(key=lambda x: x['date'], reverse=True)\n\n# 显示最新的10篇论文\nprint(\"\\n=== 最新的10篇粒子群算法改进相关论文 ===\")\nfor i, paper in enumerate(unique_papers[:10], 1):\n    print(f\"\\n{i}. {paper['title']}\")\n    print(f\"   作者: {paper['authors']}\")\n    print(f\"   日期: {paper['date']}\")\n    print(f\"   摘要: {paper['abstract'][:200]}...\")\n    print(f\"   链接: {paper['link']}\")"}
