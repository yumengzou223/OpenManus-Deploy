2026-04-07 21:18:30.726 | INFO     | app.agent.toolcall:think:89 - 🔧 Tool arguments: {"code": "# 首先导入必要的库\nimport numpy as np\nimport matplotlib.pyplot as plt\n\n# 运行PSO改进算法示例\nprint(\"正在运行粒子群算法改进技术演示...\")\nprint(\"=\" * 60)\n\n# 定义测试函数\ndef sphere_function(x):\n    return np.sum(x**2)\n\ndef rastrigin_function(x):\n    A = 10\n    return A * len(x) + np.sum(x**2 - A * np.cos(2 * np.pi * x))\n\n# 简化版的自适应PSO演示\nclass SimpleAdaptivePSO:\n    def __init__(self, objective_func, dim=10, pop_size=30, max_iter=50):\n        self.objective_func = objective_func\n        self.dim = dim\n        self.pop_size = pop_size\n        self.max_iter = max_iter\n        \n        # 初始化\n        self.positions = np.random.uniform(-5.12, 5.12, (pop_size, dim))\n        self.velocities = np.random.uniform(-1, 1, (pop_size, dim))\n        self.personal_best = self.positions.copy()\n        self.personal_best_values = np.full(pop_size, np.inf)\n        \n        self.global_best = None\n        self.global_best_value = np.inf\n        \n        self.convergence = []\n    \n    def adaptive_parameters(self, iteration):\n        # 自适应参数调整\n        w_max, w_min = 0.9, 0.4\n        w = w_max - (w_max - w_min) * (iteration / self.max_iter)\n        \n        # 学习因子调整\n        if iteration < self.max_iter * 0.3:\n            c1, c2 = 2.5, 1.5  # 强调探索\n        elif iteration < self.max_iter * 0.7:\n            c1, c2 = 2.0, 2.0  # 平衡\n        else:\n            c1, c2 = 1.5, 2.5  # 强调开发\n            \n        return w, c1, c2\n    \n    def optimize(self):\n        print(f\"优化维度: {self.dim}, 种群大小: {self.pop_size}, 最大迭代: {self.max_iter}\")\n        \n        for iter in range(self.max_iter):\n            # 评估适应度\n            for i in range(self.pop_size):\n                fitness = self.objective_func(self.positions[i])\n                \n                if fitness < self.personal_best_values[i]:\n                    self.personal_best_values[i] = fitness\n                    self.personal_best[i] = self.positions[i].copy()\n                    \n                    if fitness < self.global_best_value:\n                        self.global_best_value = fitness\n                        self.global_best = self.positions[i].copy()\n            \n            self.convergence.append(self.global_best_value)\n            \n            # 更新参数\n            w, c1, c2 = self.adaptive_parameters(iter)\n            \n            # 更新速度和位置\n            for i in range(self.pop_size):\n                r1 = np.random.random(self.dim)\n                r2 = np.random.random(self.dim)\n                \n                cognitive = c1 * r1 * (self.personal_best[i] - self.positions[i])\n                social = c2 * r2 * (self.global_best - self.positions[i])\n                \n                self.velocities[i] = w * self.velocities[i] + cognitive + social\n                self.positions[i] += self.velocities[i]\n                \n                # 边界处理\n                self.positions[i] = np.clip(self.positions[i], -5.12, 5.12)\n            \n            if iter % 10 == 0:\n                print(f\"迭代 {iter:3d}: 最优值 = {self.global_best_value:.6f}\")\n        \n        print(f\"最终结果: 最优值 = {self.global_best_value:.10f}\")\n        return self.global_best, self.global_best_value, self.convergence\n\n# 运行演示\nprint(\"\\n演示1: 自适应PSO在Sphere函数上的优化\")\nprint(\"-\" * 40)\n\npso1 = SimpleAdaptivePSO(sphere_function, dim=10, pop_size=20, max_iter=50)\nbest_sol1, best_val1, conv1 = pso1.optimize()\n\nprint(\"\\n演示2: 自适应PSO在Rastrigin函数上的优化\")\nprint(\"-\" * 40)\n\npso2 = SimpleAdaptivePSO(rastrigin_function, dim=10, pop_size=20, max_iter=50)\nbest_sol2, best_val2, conv2 = pso2.optimize()\n\n# 绘制收敛曲线\nplt.figure(figsize=(12, 5))\n\nplt.subplot(1, 2, 1)\nplt.plot(conv1, 'b-', linewidth=2)\nplt.xlabel('迭代次数')\nplt.ylabel('适应度值')\nplt.title('Sphere函数 - 自适应PSO收敛曲线')\nplt.grid(True, alpha=0.3)\nplt.yscale('log')\n\nplt.subplot(1, 2, 2)\nplt.plot(conv2, 'r-', linewidth=2)\nplt.xlabel('迭代次数')\nplt.ylabel('适应度值')\nplt.title('Rastrigin函数 - 自适应PSO收敛曲线')\nplt.grid(True, alpha=0.3)\nplt.yscale('log')\n\nplt.tight_layout()\nplt.show()\n\nprint(\"\\n\" + \"=\" * 60)\nprint(\"粒子群算法最新改进技术总结:\")\nprint(\"=\" * 60)\nprint(\"\"\"\n1. 参数自适应策略:\n   - 惯性权重非线性递减\n   - 学习因子动态调整\n   - 基于迭代阶段的不同策略\n\n2. 混合算法技术:\n   - PSO与遗传算法(GA)结合\n   - PSO与模拟退火(SA)结合\n   - 多种群协同优化\n\n3. 多样性保持机制:\n   - 混沌扰动避免早熟\n   - 拓扑结构改进\n   - 排斥操作和重初始化\n\n4. 应用扩展:\n   - 深度学习超参数优化\n   - 多目标优化问题\n   - 动态环境适应\n\"\"\")\n\nprint(\"当前研究热点:\")\nprint(\"-\" * 40)\nhot_topics = [\n    \"1. 量子粒子群算法(QPSO)\",\n    \"2. 基于深度学习的参数预测\",\n    \"3. 联邦学习中的分布式PSO\",\n    \"4. 多模态优化改进\",\n    \"5. 大规模并行PSO实现\"\n]\n\nfor topic in hot_topics:\n    print(topic)\n\nprint(\"\\n\" + \"=\" * 60)\nprint(\"已生成完整报告和示例代码:\")\nprint(\"1. 粒子群算法最新研究进展报告.md - 详细的研究进展分析\")\nprint(\"2. PSO_改进算法示例.py - 包含多种改进技术的完整代码\")\nprint(\"=\" * 60)"}
