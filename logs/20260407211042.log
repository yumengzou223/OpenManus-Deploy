2026-04-07 21:14:58.655 | INFO     | app.agent.toolcall:think:89 - 🔧 Tool arguments: {"command": "create", "path": "F:\\openmanus\\OpenManus\\workspace\\pso_advanced_examples.py", "file_text": "\"\"\"\n粒子群算法(PSO)高级改进示例\n包含最新研究中的几种改进技术\n\"\"\"\n\nimport numpy as np\nimport matplotlib.pyplot as plt\nfrom typing import List, Tuple, Callable\nimport time\n\nclass AdaptivePSO:\n    \"\"\"自适应粒子群算法 - 2023年改进版本\"\"\"\n    \n    def __init__(self, \n                 objective_func: Callable,\n                 dim: int,\n                 bounds: Tuple[float, float],\n                 n_particles: int = 30,\n                 max_iter: int = 100,\n                 w_min: float = 0.4,\n                 w_max: float = 0.9,\n                 c1: float = 2.0,\n                 c2: float = 2.0):\n        \n        self.objective_func = objective_func\n        self.dim = dim\n        self.bounds = bounds\n        self.n_particles = n_particles\n        self.max_iter = max_iter\n        \n        # 自适应参数\n        self.w_min = w_min\n        self.w_max = w_max\n        self.c1 = c1\n        self.c2 = c2\n        \n        # 初始化粒子\n        self.positions = np.random.uniform(bounds[0], bounds[1], \n                                          (n_particles, dim))\n        self.velocities = np.zeros((n_particles, dim))\n        \n        # 个体最优和全局最优\n        self.pbest_positions = self.positions.copy()\n        self.pbest_values = np.full(n_particles, np.inf)\n        \n        self.gbest_position = None\n        self.gbest_value = np.inf\n        \n        # 记录收敛过程\n        self.convergence_history = []\n        \n    def adaptive_inertia_weight(self, iteration: int) -> float:\n        \"\"\"自适应惯性权重 - 基于迭代次数和适应度改进\"\"\"\n        # 非线性递减策略\n        w = self.w_max - (self.w_max - self.w_min) * (iteration / self.max_iter) ** 2\n        return w\n    \n    def adaptive_learning_factors(self, iteration: int) -> Tuple[float, float]:\n        \"\"\"自适应学习因子 - 2024年改进策略\"\"\"\n        # 认知因子递减，社会因子递增\n        c1_adaptive = self.c1 * (1 - iteration / self.max_iter)\n        c2_adaptive = self.c2 * (iteration / self.max_iter)\n        return max(c1_adaptive, 0.5), max(c2_adaptive, 0.5)\n    \n    def update_velocity_position(self, iteration: int):\n        \"\"\"更新速度和位置 - 包含混沌扰动\"\"\"\n        w = self.adaptive_inertia_weight(iteration)\n        c1_adaptive, c2_adaptive = self.adaptive_learning_factors(iteration)\n        \n        # 标准PSO更新\n        r1 = np.random.rand(self.n_particles, self.dim)\n        r2 = np.random.rand(self.n_particles, self.dim)\n        \n        cognitive = c1_adaptive * r1 * (self.pbest_positions - self.positions)\n        social = c2_adaptive * r2 * (self.gbest_position - self.positions)\n        \n        self.velocities = w * self.velocities + cognitive + social\n        \n        # 速度限制\n        v_max = 0.2 * (self.bounds[1] - self.bounds[0])\n        self.velocities = np.clip(self.velocities, -v_max, v_max)\n        \n        # 更新位置\n        self.positions += self.velocities\n        \n        # 边界处理\n        self.positions = np.clip(self.positions, self.bounds[0], self.bounds[1])\n        \n        # 混沌扰动（防止早熟收敛）\n        if iteration % 20 == 0 and iteration > 0:\n            chaos_factor = 0.1 * (1 - iteration / self.max_iter)\n            chaos = chaos_factor * (np.random.rand(self.n_particles, self.dim) - 0.5)\n            self.positions += chaos\n            self.positions = np.clip(self.positions, self.bounds[0], self.bounds[1])\n    \n    def optimize(self):\n        \"\"\"执行优化过程\"\"\"\n        print(\"开始自适应PSO优化...\")\n        start_time = time.time()\n        \n        # 初始化评估\n        for i in range(self.n_particles):\n            fitness = self.objective_func(self.positions[i])\n            self.pbest_values[i] = fitness\n            self.pbest_positions[i] = self.positions[i].copy()\n            \n            if fitness < self.gbest_value:\n                self.gbest_value = fitness\n                self.gbest_position = self.positions[i].copy()\n        \n        # 迭代优化\n        for iter in range(self.max_iter):\n            # 更新速度和位置\n            self.update_velocity_position(iter)\n            \n            # 评估新位置\n            for i in range(self.n_particles):\n                fitness = self.objective_func(self.positions[i])\n                \n                # 更新个体最优\n                if fitness < self.pbest_values[i]:\n                    self.pbest_values[i] = fitness\n                    self.pbest_positions[i] = self.positions[i].copy()\n                \n                # 更新全局最优\n                if fitness < self.gbest_value:\n                    self.gbest_value = fitness\n                    self.gbest_position = self.positions[i].copy()\n            \n            # 记录收敛历史\n            self.convergence_history.append(self.gbest_value)\n            \n            # 打印进度\n            if iter % 20 == 0:\n                print(f\"迭代 {iter}: 最优值 = {self.gbest_value:.6f}\")\n        \n        end_time = time.time()\n        print(f\"\\n优化完成!\")\n        print(f\"总耗时: {end_time - start_time:.2f}秒\")\n        print(f\"最终最优值: {self.gbest_value:.10f}\")\n        print(f\"最优解: {self.gbest_position}\")\n        \n        return self.gbest_position, self.gbest_value, self.convergence_history\n\n\nclass HybridPSO_GA:\n    \"\"\"PSO-GA混合算法 - 2024年最新研究\"\"\"\n    \n    def __init__(self, objective_func, dim, bounds, \n                 n_particles=30, max_iter=100,\n                 crossover_rate=0.8, mutation_rate=0.1):\n        \n        self.objective_func = objective_func\n        self.dim = dim\n        self.bounds = bounds\n        self.n_particles = n_particles\n        self.max_iter = max_iter\n        self.crossover_rate = crossover_rate\n        self.mutation_rate = mutation_rate\n        \n        # PSO参数\n        self.w = 0.7\n        self.c1 = 1.5\n        self.c2 = 1.5\n        \n        # 初始化\n        self.positions = np.random.uniform(bounds[0], bounds[1], \n                                          (n_particles, dim))\n        self.velocities = np.zeros((n_particles, dim))\n        \n        self.pbest_positions = self.positions.copy()\n        self.pbest_values = np.full(n_particles, np.inf)\n        \n        self.gbest_position = None\n        self.gbest_value = np.inf\n        \n        self.convergence_history = []\n    \n    def genetic_operations(self, iteration):\n        \"\"\"遗传算法操作：选择、交叉、变异\"\"\"\n        # 选择（基于适应度的轮盘赌选择）\n        fitnesses = np.array([self.objective_func(pos) for pos in self.positions])\n        max_fitness = np.max(fitnesses)\n        normalized_fitness = max_fitness - fitnesses + 1e-10\n        selection_probs = normalized_fitness / np.sum(normalized_fitness)\n        \n        selected_indices = np.random.choice(\n            self.n_particles, \n            size=self.n_particles,\n            p=selection_probs\n        )\n        \n        new_positions = self.positions[selected_indices].copy()\n        \n        # 交叉操作\n        for i in range(0, self.n_particles-1, 2):\n            if np.random.rand() < self.crossover_rate:\n                # 算术交叉\n                alpha = np.random.rand()\n                parent1 = new_positions[i]\n                parent2 = new_positions[i+1]\n                \n                child1 = alpha * parent1 + (1 - alpha) * parent2\n                child2 = alpha * parent2 + (1 - alpha) * parent1\n                \n                new_positions[i] = child1\n                new_positions[i+1] = child2\n        \n        # 变异操作\n        for i in range(self.n_particles):\n            if np.random.rand() < self.mutation_rate:\n                # 高斯变异\n                mutation_strength = 0.1 * (1 - iteration / self.max_iter)\n                mutation = mutation_strength * np.random.randn(self.dim)\n                new_positions[i] += mutation\n                new_positions[i] = np.clip(new_positions[i], \n                                          self.bounds[0], \n                                          self.bounds[1])\n        \n        return new_positions\n    \n    def optimize(self):\n        \"\"\"执行混合优化\"\"\"\n        print(\"开始PSO-GA混合优化...\")\n        \n        # 初始化评估\n        for i in range(self.n_particles):\n            fitness = self.objective_func(self.positions[i])\n            self.pbest_values[i] = fitness\n            self.pbest_positions[i] = self.positions[i].copy()\n            \n            if fitness < self.gbest_value:\n                self.gbest_value = fitness\n                self.gbest_position = self.positions[i].copy()\n        \n        # 迭代优化\n        for iter in range(self.max_iter):\n            # PSO更新\n            r1 = np.random.rand(self.n_particles, self.dim)\n            r2 = np.random.rand(self.n_particles, self.dim)\n            \n            cognitive = self.c1 * r1 * (self.pbest_positions - self.positions)\n            social = self.c2 * r2 * (self.gbest_position - self.positions)\n            \n            self.velocities = self.w * self.velocities + cognitive + social\n            self.positions += self.velocities\n            self.positions = np.clip(self.positions, self.bounds[0], self.bounds[1])\n            \n            # 每10代执行一次遗传操作\n            if iter % 10 == 0:\n                self.positions = self.genetic_operations(iter)\n            \n            # 评估和更新\n            for i in range(self.n_particles):\n                fitness = self.objective_func(self.positions[i])\n                \n                if fitness < self.pbest_values[i]:\n                    self.pbest_values[i] = fitness\n                    self.pbest_positions[i] = self.positions[i].copy()\n                \n                if fitness < self.gbest_value:\n                    self.gbest_value = fitness\n                    self.gbest_position = self.positions[i].copy()\n            \n            self.convergence_history.append(self.gbest_value)\n            \n            if iter % 20 == 0:\n                print(f\"迭代 {iter}: 最优值 = {self.gbest_value:.6f}\")\n        \n        print(f\"\\n混合优化完成!\")\n        print(f\"最终最优值: {self.gbest_value:.10f}\")\n        \n        return self.gbest_position, self.gbest_value, self.convergence_history\n\n\nclass QuantumPSO:\n    \"\"\"量子粒子群算法(QPSO) - 最新量子计算融合\"\"\"\n    \n    def __init__(self, objective_func, dim, bounds, \n                 n_particles=30, max_iter=100,\n                 contraction_expansion=1.0):\n        \n        self.objective_func = objective_func\n        self.dim = dim\n        self.bounds = bounds\n        self.n_particles = n_particles\n        self.max_iter = max_iter\n        self.alpha = contraction_expansion  # 收缩扩张系数\n        \n        # 量子行为参数\n        self.mbest = None  # 平均最优位置\n        self.positions = np.random.uniform(bounds[0], bounds[1], \n                                          (n_particles, dim))\n        \n        self.pbest_positions = self.positions.copy()\n        self.pbest_values = np.full(n_particles, np.inf)\n        \n        self.gbest_position = None\n        self.gbest_value = np.inf\n        \n        self.convergence_history = []\n    \n    def quantum_update(self, iteration):\n        \"\"\"量子更新机制\"\"\"\n        # 计算平均最优位置\n        self.mbest = np.mean(self.pbest_positions, axis=0)\n        \n        # 量子更新\n        for i in range(self.n_particles):\n            phi = np.random.rand(self.dim)\n            p = phi * self.pbest_positions[i] + (1 - phi) * self.gbest_position\n            \n            # 量子势阱中心\n            u = np.random.rand(self.dim)\n            if np.random.rand() > 0.5:\n                self.positions[i] = p + self.alpha * abs(self.mbest - self.positions[i]) * np.log(1/u)\n            else:\n                self.positions[i] = p - self.alpha * abs(self.mbest - self.positions[i]) * np.log(1/u)\n            \n            # 边界处理\n            self.positions[i] = np.clip(self.positions[i], \n                                       self.bounds[0], \n                                       self.bounds[1])\n    \n    def optimize(self):\n        \"\"\"执行量子PSO优化\"\"\"\n        print(\"开始量子PSO优化...\")\n        \n        # 初始化评估\n        for i in range(self.n_particles):\n            fitness = self.objective_func(self.positions[i])\n            self.pbest_values[i] = fitness\n            self.pbest_positions[i] = self.positions[i].copy()\n            \n            if fitness < self.gbest_value:\n                self.gbest_value = fitness\n                self.gbest_position = self.positions[i].copy()\n        \n        # 迭代优化\n        for iter in range(self.max_iter):\n            # 量子更新\n            self.quantum_update(iter)\n            \n            # 自适应调整alpha\n            self.alpha = 0.5 + 0.5 * (1 - iter / self.max_iter)\n            \n            # 评估和更新\n            for i in range(self.n_particles):\n                fitness = self.objective_func(self.positions[i])\n                \n                if fitness < self.pbest_values[i]:\n                    self.pbest_values[i] = fitness\n                    self.pbest_positions[i] = self.positions[i].copy()\n                \n                if fitness < self.gbest_value:\n                    self.gbest_value = fitness\n                    self.gbest_position = self.positions[i].copy()\n            \n            self.convergence_history.append(self.gbest_value)\n            \n            if iter % 20 == 0:\n                print(f\"迭代 {iter}: 最优值 = {self.gbest_value:.6f}\")\n        \n        print(f\"\\n量子PSO优化完成!\")\n        print(f\"最终最优值: {self.gbest_value:.10f}\")\n        \n        return self.gbest_position, self.gbest_value, self.convergence_history\n\n\n# 测试函数\ndef sphere_function(x):\n    \"\"\"Sphere函数 - 经典测试函数\"\"\"\n    return np.sum(x**2)\n\ndef rastrigin_function(x):\n    \"\"\"Rastrigin函数 - 多模态测试函数\"\"\"\n    A = 10\n    return A * len(x) + np.sum(x**2 - A * np.cos(2 * np.pi * x))\n\ndef ackley_function(x):\n    \"\"\"Ackley函数 - 复杂多模态函数\"\"\"\n    a = 20\n    b = 0.2\n    c = 2 * np.pi\n    n = len(x)\n    \n    sum1 = np.sum(x**2)\n    sum2 = np.sum(np.cos(c * x))\n    \n    term1 = -a * np.exp(-b * np.sqrt(sum1 / n))\n    term2 = -np.exp(sum2 / n)\n    \n    return term1 + term2 + a + np.exp(1)\n\n\ndef main():\n    \"\"\"主函数：比较不同改进算法\"\"\"\n    print(\"=\" * 60)\n    print(\"粒子群算法最新改进技术比较\")\n    print(\"=\" * 60)\n    \n    # 测试配置\n    dim = 10\n    bounds = (-5.0, 5.0)\n    n_particles = 30\n    max_iter = 100\n    \n    # 选择测试函数\n    test_func = sphere_function\n    print(f\"\\n测试函数: Sphere Function (维度={dim})\")\n    print(f\"搜索范围: [{bounds[0]}, {bounds[1]}]\")\n    print(f\"粒子数: {n_particles}, 最大迭代: {max_iter}\")\n    \n    # 1. 自适应PSO\n    print(\"\\n\" + \"=\" * 40)\n    print(\"1. 自适应PSO算法\")\n    print(\"=\" * 40)\n    apso = AdaptivePSO(test_func, dim, bounds, n_particles, max_iter)\n    apso_best_pos, apso_best_val, apso_history = apso.optimize()\n    \n    # 2. PSO-GA混合算法\n    print(\"\\n\" + \"=\" * 40)\n    print(\"2. PSO-GA混合算法\")\n    print(\"=\" * 40)\n    hybrid = HybridPSO_GA(test_func, dim, bounds, n_particles, max_iter)\n    hybrid_best_pos, hybrid_best_val, hybrid_history = hybrid.optimize()\n    \n    # 3. 量子PSO\n    print(\"\\n\" + \"=\" * 40)\n    print(\"3. 量子粒子群算法(QPSO)\")\n    print(\"=\" * 40)\n    qpso = QuantumPSO(test_func, dim, bounds, n_particles, max_iter)\n    qpso_best_pos, qpso_best_val, qpso_history = qpso.optimize()\n    \n    # 绘制收敛曲线\n    plt.figure(figsize=(12, 8))\n    \n    plt.subplot(2, 2, 1)\n    plt.plot(apso_history, label='自适应PSO', linewidth=2)\n    plt.plot(hybrid_history, label='PSO-GA混合', linewidth=2)\n    plt.plot(qpso_history, label='量子PSO', linewidth=2)\n    plt.xlabel('迭代次数')\n    plt.ylabel('最优适应度值')\n    plt.title('不同PSO改进算法的收敛曲线')\n    plt.legend()\n    plt
