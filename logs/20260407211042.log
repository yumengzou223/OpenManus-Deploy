alues[i] = fitness\n                    self.pbest_positions[i] = self.positions[i].copy()\n                \n                # 更新全局最优\n                if fitness < self.gbest_value:\n                    self.gbest_value = fitness\n                    self.gbest_position = self.positions[i].copy()\n            \n            # 更新速度和位置\n            self._update_velocities()\n            self._update_positions()\n            \n            # 记录收敛历史\n            self.convergence_history.append(self.gbest_value)\n            \n            # 打印进度\n            if iteration % 10 == 0:\n                print(f\"Iteration {iteration}: Best fitness = {self.gbest_value:.6f}\")\n        \n        return {\n            'best_position': self.gbest_position,\n            'best_value': self.gbest_value,\n            'convergence_history': self.convergence_history\n        }\n    \n    def _update_velocities(self):\n        \"\"\"更新速度（需要在子类中实现）\"\"\"\n        raise NotImplementedError\n    \n    def _update_positions(self):\n        \"\"\"更新位置\"\"\"\n        self.positions += self.velocities\n        # 边界处理\n        self.positions = np.clip(self.positions, self.bounds[0], self.bounds[1])\n\n\nclass AdaptiveWeightPSO(AdvancedPSO):\n    \"\"\"自适应惯性权重PSO\"\"\"\n    \n    def __init__(self, n_particles: int, dimensions: int, bounds: Tuple[float, float],\n                 max_iter: int = 100, w_max: float = 0.9, w_min: float = 0.4):\n        super().__init__(n_particles, dimensions, bounds, max_iter)\n        self.w_max = w_max\n        self.w_min = w_min\n        \n    def _update_velocities(self, iteration: int):\n        \"\"\"更新速度，使用自适应惯性权重\"\"\"\n        # 线性递减惯性权重\n        w = self.w_max - (self.w_max - self.w_min) * (iteration / self.max_iter)\n        \n        r1 = np.random.rand(self.n_particles, self.dimensions)\n        r2 = np.random.rand(self.n_particles, self.dimensions)\n        \n        cognitive = self.c1 * r1 * (self.pbest_positions - self.positions)\n        social = self.c2 * r2 * (self.gbest_position - self.positions)\n        \n        self.velocities = w * self.velocities + cognitive + social\n\n\nclass ConstrictionCoefficientPSO(AdvancedPSO):\n    \"\"\"收缩因子PSO (Clerc's PSO)\"\"\"\n    \n    def __init__(self, n_particles: int, dimensions: int, bounds: Tuple[float, float],\n                 max_iter: int = 100):\n        super().__init__(n_particles, dimensions, bounds, max_iter)\n        # 计算收缩因子\n        phi = self.c1 + self.c2\n        self.kappa = 2.0 / abs(2 - phi - np.sqrt(phi**2 - 4*phi))\n        \n    def _update_velocities(self, iteration: int):\n        \"\"\"使用收缩因子更新速度\"\"\"\n        r1 = np.random.rand(self.n_particles, self.dimensions)\n        r2 = np.random.rand(self.n_particles, self.dimensions)\n        \n        cognitive = self.c1 * r1 * (self.pbest_positions - self.positions)\n        social = self.c2 * r2 * (self.gbest_position - self.positions)\n        \n        velocity = self.velocities + cognitive + social\n        self.velocities = self.kappa * velocity\n\n\nclass QuantumPSO(AdvancedPSO):\n    \"\"\"量子粒子群算法(QPSO)\"\"\"\n    \n    def __init__(self, n_particles: int, dimensions: int, bounds: Tuple[float, float],\n                 max_iter: int = 100, alpha: float = 0.75):\n        super().__init__(n_particles, dimensions, bounds, max_iter)\n        self.alpha = alpha  # 收缩扩张系数\n        \n    def _update_positions(self, iteration: int):\n        \"\"\"QPSO的位置更新公式\"\"\"\n        # 计算平均最优位置\n        mbest = np.mean(self.pbest_positions, axis=0)\n        \n        for i in range(self.n_particles):\n            phi = np.random.rand(self.dimensions)\n            p = phi * self.pbest_positions[i] + (1 - phi) * self.gbest_position\n            \n            u = np.random.rand(self.dimensions)\n            if np.random.rand() > 0.5:\n                self.positions[i] = p + self.alpha * abs(mbest - self.positions[i]) * np.log(1/u)\n            else:\n                self.positions[i] = p - self.alpha * abs(mbest - self.positions[i]) * np.log(1/u)\n        \n        # 边界处理\n        self.positions = np.clip(self.positions, self.bounds[0], self.bounds[1])\n\n\nclass HybridPSO_GA(AdvancedPSO):\n    \"\"\"PSO与遗传算法混合算法\"\"\"\n    \n    def __init__(self, n_particles: int, dimensions: int, bounds: Tuple[float, float],\n                 max_iter: int = 100, crossover_rate: float = 0.8, mutation_rate: float = 0.1):\n        super().__init__(n_particles, dimensions, bounds, max_iter)\n        self.crossover_rate = crossover_rate\n        self.mutation_rate = mutation_rate\n        \n    def optimize(self, objective_func: Callable) -> Dict:\n        \"\"\"混合优化算法\"\"\"\n        for iteration in range(self.max_iter):\n            # PSO更新\n            for i in range(self.n_particles):\n                fitness = objective_func(self.positions[i])\n                \n                if fitness < self.pbest_values[i]:\n                    self.pbest_values[i] = fitness\n                    self.pbest_positions[i] = self.positions[i].copy()\n                \n                if fitness < self.gbest_value:\n                    self.gbest_value = fitness\n                    self.gbest_position = self.positions[i].copy()\n            \n            # PSO速度更新\n            self._update_velocities(iteration)\n            self._update_positions()\n            \n            # 遗传算法操作（每10代执行一次）\n            if iteration % 10 == 0 and iteration > 0:\n                self._genetic_operations(objective_func)\n            \n            self.convergence_history.append(self.gbest_value)\n            \n            if iteration % 10 == 0:\n                print(f\"Iteration {iteration}: Best fitness = {self.gbest_value:.6f}\")\n        \n        return {\n            'best_position': self.gbest_position,\n            'best_value': self.gbest_value,\n            'convergence_history': self.convergence_history\n        }\n    \n    def _genetic_operations(self, objective_func: Callable):\n        \"\"\"遗传算法操作：选择、交叉、变异\"\"\"\n        # 选择（锦标赛选择）\n        selected_indices = self._tournament_selection()\n        \n        # 交叉\n        offspring = self._crossover(selected_indices)\n        \n        # 变异\n        offspring = self._mutation(offspring)\n        \n        # 评估并替换最差粒子\n        for i, idx in enumerate(np.argsort(self.pbest_values)[-len(offspring):]):\n            new_fitness = objective_func(offspring[i])\n            if new_fitness < self.pbest_values[idx]:\n                self.positions[idx] = offspring[i]\n                self.pbest_positions[idx] = offspring[i]\n                self.pbest_values[idx] = new_fitness\n    \n    def _tournament_selection(self, tournament_size: int = 3) -> List[int]:\n        \"\"\"锦标赛选择\"\"\"\n        selected = []\n        for _ in range(self.n_particles):\n            contestants = np.random.choice(self.n_particles, tournament_size, replace=False)\n            winner = contestants[np.argmin(self.pbest_values[contestants])]\n            selected.append(winner)\n        return selected\n    \n    def _crossover(self, selected_indices: List[int]) -> np.ndarray:\n        \"\"\"模拟二进制交叉\"\"\"\n        offspring = []\n        for i in range(0, len(selected_indices)-1, 2):\n            if np.random.rand() < self.crossover_rate:\n                parent1 = self.pbest_positions[selected_indices[i]]\n                parent2 = self.pbest_positions[selected_indices[i+1]]\n                \n                # 模拟二进制交叉\n                beta = np.random.rand(self.dimensions)\n                child1 = 0.5 * ((1+beta)*parent1 + (1-beta)*parent2)\n                child2 = 0.5 * ((1-beta)*parent1 + (1+beta)*parent2)\n                \n                offspring.extend([child1, child2])\n            else:\n                offspring.extend([\n                    self.pbest_positions[selected_indices[i]],\n                    self.pbest_positions[selected_indices[i+1]]\n                ])\n        return np.array(offspring[:self.n_particles])\n    \n    def _mutation(self, offspring: np.ndarray) -> np.ndarray:\n        \"\"\"多项式变异\"\"\"\n        for i in range(len(offspring)):\n            if np.random.rand() < self.mutation_rate:\n                mutation_point = np.random.randint(0, self.dimensions)\n                delta = np.random.randn() * 0.1  # 小幅度变异\n                offspring[i, mutation_point] += delta\n                offspring[i, mutation_point] = np.clip(\n                    offspring[i, mutation_point], self.bounds[0], self.bounds[1]\n                )\n        return offspring\n\n\nclass MultiObjectivePSO:\n    \"\"\"多目标粒子群算法(MOPSO)\"\"\"\n    \n    def __init__(self, n_particles: int, dimensions: int, bounds: Tuple[float, float],\n                 max_iter: int = 100, archive_size: int = 100):\n        self.n_particles = n_particles\n        self.dimensions = dimensions\n        self.bounds = bounds\n        self.max_iter = max_iter\n        self.archive_size = archive_size\n        \n        # 初始化\n        self.positions = np.random.uniform(bounds[0], bounds[1], (n_particles, dimensions))\n        self.velocities = np.random.uniform(-1, 1, (n_particles, dimensions))\n        self.pbest_positions = self.positions.copy()\n        \n        # 外部档案（存储非支配解）\n        self.archive = []\n        self.archive_fitness = []\n        \n    def optimize(self, objective_funcs: List[Callable]) -> Dict:\n        \"\"\"多目标优化\"\"\"\n        for iteration in range(self.max_iter):\n            # 计算所有目标函数值\n            fitness_matrix = np.array([[func(pos) for func in objective_funcs] \n                                      for pos in self.positions])\n            \n            # 更新个体最优（基于Pareto支配）\n            self._update_pbest(fitness_matrix)\n            \n            # 更新外部档案\n            self._update_archive(fitness_matrix)\n            \n            # 选择全局引导者\n            leaders = self._select_leaders()\n            \n            # 更新速度和位置\n            self._update_velocities(leaders, iteration)\n            self._update_positions()\n            \n            if iteration % 20 == 0:\n                print(f\"Iteration {iteration}: Archive size = {len(self.archive)}\")\n        \n        return {\n            'pareto_front': self.archive,\n            'pareto_fitness': self.archive_fitness\n        }\n    \n    def _update_pbest(self, fitness_matrix: np.ndarray):\n        \"\"\"基于Pareto支配更新个体最优\"\"\"\n        for i in range(self.n_particles):\n            current_fitness = fitness_matrix[i]\n            pbest_fitness = np.array([func(self.pbest_positions[i]) \n                                     for func in self.objective_funcs])\n            \n            # 如果当前解支配pbest，则更新\n            if self._dominates(current_fitness, pbest_fitness):\n                self.pbest_positions[i] = self.positions[i].copy()\n            # 如果互不支配，随机选择\n            elif not self._dominates(pbest_fitness, current_fitness):\n                if np.random.rand() > 0.5:\n                    self.pbest_positions[i] = self.positions[i].copy()\n    \n    def _update_archive(self, fitness_matrix: np.ndarray):\n        \"\"\"更新外部档案\"\"\"\n        # 添加当前非支配解\n        for i in range(self.n_particles):\n            is_dominated = False\n            to_remove = []\n            \n            for j, (arch_pos, arch_fit) in enumerate(zip(self.archive, self.archive_fitness)):\n                if self._dominates(arch_fit, fitness_matrix[i]):\n                    is_dominated = True\n                    break\n                elif self._dominates(fitness_matrix[i], arch_fit):\n                    to_remove.append(j)\n            \n            if not is_dominated:\n                # 移除被支配的解\n                for idx in sorted(to_remove, reverse=True):\n                    self.archive.pop(idx)\n                    self.archive_fitness.pop(idx)\n                \n                # 添加新解\n                self.archive.append(self.positions[i].copy())\n                self.archive_fitness.append(fitness_matrix[i].copy())\n        \n        # 维护档案大小\n        if len(self.archive) > self.archive_size:\n            self._truncate_archive()\n    \n    def _select_leaders(self) -> np.ndarray:\n        \"\"\"基于拥挤距离选择引导者\"\"\"\n        if len(self.archive) == 0:\n            return np.random.choice(self.n_particles, self.n_particles, replace=True)\n        \n        # 计算拥挤距离\n        crowding_distances = self._calculate_crowding_distance()\n        \n        # 基于拥挤距离的概率选择\n        probabilities = crowding_distances / np.sum(crowding_distances)\n        leaders_idx = np.random.choice(len(self.archive), self.n_particles, \n                                      p=probabilities, replace=True)\n        \n        return np.array([self.archive[idx] for idx in leaders_idx])\n    \n    def _calculate_crowding_distance(self) -> np.ndarray:\n        \"\"\"计算拥挤距离\"\"\"\n        n_solutions = len(self.archive)\n        if n_solutions <= 2:\n            return np.ones(n_solutions)\n        \n        distances = np.zeros(n_solutions)\n        fitness_array = np.array(self.archive_fitness)\n        \n        for m in range(fitness_array.shape[1]):  # 对每个目标函数\n            sorted_idx = np.argsort(fitness_array[:, m])\n            distances[sorted_idx[0]] = distances[sorted_idx[-1]] = np.inf\n            \n            f_max = fitness_array[sorted_idx[-1], m]\n            f_min = fitness_array[sorted_idx[0], m]\n            \n            if f_max != f_min:\n                for i in range(1, n_solutions-1):\n                    distances[sorted_idx[i]] += (\n                        fitness_array[sorted_idx[i+1], m] - \n                        fitness_array[sorted_idx[i-1], m]\n                    ) / (f_max - f_min)\n        \n        return distances\n    \n    def _dominates(self, a: np.ndarray, b: np.ndarray) -> bool:\n        \"\"\"判断a是否支配b\"\"\"\n        return np.all(a <= b) and np.any(a < b)\n\n\n# 测试函数\ndef sphere_function(x):\n    \"\"\"Sphere测试函数\"\"\"\n    return np.sum(x**2)\n\ndef rastrigin_function(x):\n    \"\"\"Rastrigin测试函数（多模态）\"\"\"\n    A = 10\n    return A * len(x) + np.sum(x**2 - A * np.cos(2 * np.pi * x))\n\ndef ackley_function(x):\n    \"\"\"Ackley测试函数\"\"\"\n    a = 20\n    b = 0.2\n    c = 2 * np.pi\n    n = len(x)\n    sum1 = np.sum(x**2)\n    sum2 = np.sum(np.cos(c * x))\n    term1 = -a * np.exp(-b * np.sqrt(sum1/n))\n    term2 = -np.exp(sum2/n)\n    return term1 + term2 + a + np.exp(1)\n\n\ndef test_algorithms():\n    \"\"\"测试各种PSO算法\"\"\"\n    print(\"测试各种粒子群算法改进版本...\")\n    print(\"=\" * 60)\n    \n    # 测试配置\n    n_particles = 30\n    dimensions = 10\n    bounds = (-5.12, 5.12)  # Rastrigin函数的典型范围\n   
