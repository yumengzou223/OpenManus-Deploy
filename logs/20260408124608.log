text:\n                    authors.append(name_elem.text.strip())\n            paper['authors'] = authors\n            \n            # 提取摘要\n            summary_elem = entry.find('atom:summary', ns)\n            paper['abstract'] = summary_elem.text.strip() if summary_elem is not None and summary_elem.text else \"No abstract\"\n            \n            # 提取发布日期\n            published_elem = entry.find('atom:published', ns)\n            if published_elem is not None and published_elem.text:\n                published_date = published_elem.text[:10]\n                paper['published'] = published_date\n            else:\n                paper['published'] = \"Unknown\"\n            \n            # 提取arXiv ID和链接\n            id_elem = entry.find('atom:id', ns)\n            if id_elem is not None and id_elem.text:\n                paper['arxiv_id'] = id_elem.text.split('/')[-1]\n                paper['link'] = f\"https://arxiv.org/abs/{paper['arxiv_id']}\"\n            else:\n                paper['arxiv_id'] = \"Unknown\"\n                paper['link'] = \"Unknown\"\n            \n            # 避免重复\n            if not any(p['arxiv_id'] == paper['arxiv_id'] for p in all_papers):\n                all_papers.append(paper)\n                print(f\"找到: {title}\")\n    \n    except Exception as e:\n        print(f\"搜索错误: {e}\")\n\nprint(f\"\\n总共找到 {len(all_papers)} 篇RAG相关论文\")\n\n# 按发布日期排序\nall_papers.sort(key=lambda x: x['published'], reverse=True)\n\n# 保存到文件\nwith open('rag_survey_papers.json', 'w', encoding='utf-8') as f:\n    json.dump(all_papers, f, ensure_ascii=False, indent=2)\n\nprint(f\"论文信息已保存到 rag_survey_papers.json\")\n\n# 显示论文摘要\nprint(\"\\n\" + \"=\"*80)\nprint(\"RAG相关论文摘要\")\nprint(\"=\"*80)\n\nfor i, paper in enumerate(all_papers[:10], 1):\n    print(f\"\\n[{i}] {paper['title']}\")\n    print(f\"作者: {', '.join(paper['authors'][:3])}{'...' if len(paper['authors']) > 3 else ''}\")\n    print(f\"发布日期: {paper['published']}\")\n    print(f\"arXiv ID: {paper['ar